# Backend env template — copy to backend/.env and fill in.
# The real backend/.env is gitignored; never commit secrets.
#
# Production values live in Render → fitwiz-zqi3 service → Environment.
# Keep this file in sync with new env vars added to backend/core/config.py.

# ============================================================
# Gemini (LLM)
# ============================================================
# Get your API key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ============================================================
# Server
# ============================================================
HOST=0.0.0.0
PORT=8000
DEBUG=true
ENVIRONMENT=development

# ============================================================
# Database
# ============================================================
# Local dev uses sqlite. Prod uses Supabase Postgres via SUPABASE_URL.
DATABASE_URL=sqlite+aiosqlite:///./data/fitness_coach.db

# Supabase — required for auth + production data
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...service_role...    # service_role key (NOT anon — backend bypasses RLS)
SUPABASE_JWT_SECRET=your-jwt-signing-secret

# ============================================================
# RAG (ChromaDB)
# ============================================================
CHROMA_PERSIST_DIR=./data/chroma
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.7

# ============================================================
# RevenueCat (subscriptions)
# ============================================================
# Server-side (read by backend):
#   REVCAT_API_KEY               v1/v2 SECRET API key (sk_...). RC Dashboard
#                                → Project Settings → API Keys → Secret Keys.
#                                Used by management endpoints + helper scripts.
#   REVENUECAT_WEBHOOK_SECRET    Bearer token configured in RC dashboard →
#                                Integrations → Webhooks. The backend rejects
#                                unsigned webhooks. MUST match exactly across:
#                                  - RC dashboard webhook config
#                                  - this file (local dev)
#                                  - Render env vars (production)
#                                Backend reads the pydantic field
#                                `revenuecat_webhook_secret` which maps to
#                                this exact uppercase env var name.
REVCAT_API_KEY=sk_your_secret_revenuecat_key_here
REVENUECAT_WEBHOOK_SECRET=whsec_choose_any_random_string

# Client-side (NOT used by backend; documented here for reference only):
#   REVENUECAT_GOOGLE_KEY  public Android client key (goog_...). Baked into
#                          the AAB at build time by mobile/flutter/scripts/
#                          build_release.sh — never hits the backend.
# REVENUECAT_GOOGLE_KEY=goog_your_public_android_key

# ============================================================
# AWS / S3 (uploads)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=

# ============================================================
# Google OAuth (Sign in with Google)
# ============================================================
GCP_OAUTH_CLIENT_ID=
GCP_OAUTH_CLIENT_SECRET=

# ============================================================
# Email (Resend)
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=Zealova <hello@zealova.com>

# ============================================================
# Sentry (error tracking)
# ============================================================
SENTRY_DSN=
SENTRY_DSN_FLUTTER=

# ============================================================
# Notifications (admin webhooks — optional)
# ============================================================
SLACK_SUPPORT_WEBHOOK=
DISCORD_WEBHOOK_URL=

# ============================================================
# Cron / scheduled jobs
# ============================================================
CRON_SECRET=
CRON_ALLOWED_IPS=

# ============================================================
# Android signing — DO NOT PUT HERE
# ============================================================
# Keystore credentials (KEYSTORE_PATH / KEYSTORE_PASSWORD / KEY_ALIAS /
# KEY_PASSWORD) belong on the BUILD machine, not the backend. Set them
# in your shell rc, in mobile/flutter/android/key.properties, or in CI
# secrets — never on Render. The backend doesn't sign Android builds.
