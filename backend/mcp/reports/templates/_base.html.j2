<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{{ title or "FitWiz Report" }}</title>
  <style>
    @page {
      size: Letter;
      margin: 0.75in;
      @bottom-center {
        content: "FitWiz  •  Page " counter(page) " / " counter(pages);
        font-family: "Helvetica", "Arial", sans-serif;
        font-size: 9pt;
        color: #888;
      }
    }

    :root {
      --accent: #4f46e5;
      --accent-soft: #eef2ff;
      --text: #111827;
      --muted: #6b7280;
      --border: #e5e7eb;
      --ok: #059669;
      --warn: #d97706;
      --bad: #dc2626;
    }

    * { box-sizing: border-box; }

    body {
      font-family: "Georgia", "Times New Roman", serif;
      font-size: 11pt;
      line-height: 1.55;
      color: var(--text);
      margin: 0;
    }

    h1, h2, h3, h4 {
      font-family: "Helvetica", "Arial", sans-serif;
      font-weight: 700;
      color: var(--text);
      margin-top: 1.4em;
      margin-bottom: 0.4em;
    }

    h1 {
      font-size: 24pt;
      color: var(--accent);
      border-bottom: 3px solid var(--accent);
      padding-bottom: 0.2em;
      margin-top: 0;
    }

    h2 {
      font-size: 16pt;
      color: var(--accent);
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.15em;
    }

    h3 {
      font-size: 13pt;
      color: var(--text);
    }

    p { margin: 0.5em 0; }

    strong { color: var(--text); }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 1.5em 0;
    }

    ul, ol { padding-left: 1.4em; }
    li { margin: 0.2em 0; }

    table {
      width: 100%;
      border-collapse: collapse;
      margin: 0.8em 0 1.2em 0;
      font-size: 10pt;
      font-family: "Helvetica", "Arial", sans-serif;
    }

    th {
      background: var(--accent-soft);
      color: var(--accent);
      text-align: left;
      padding: 0.45em 0.6em;
      border-bottom: 2px solid var(--accent);
      font-weight: 700;
    }

    td {
      padding: 0.4em 0.6em;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }

    tr:nth-child(even) td { background: #fafafa; }

    blockquote {
      margin: 0.8em 0;
      padding: 0.6em 1em;
      background: var(--accent-soft);
      border-left: 4px solid var(--accent);
      color: var(--text);
      font-style: italic;
    }

    code {
      font-family: "Menlo", "Consolas", monospace;
      font-size: 9.5pt;
      background: #f3f4f6;
      padding: 0.1em 0.35em;
      border-radius: 3px;
    }

    .report-footer {
      margin-top: 2em;
      padding-top: 0.6em;
      border-top: 1px solid var(--border);
      font-size: 9pt;
      color: var(--muted);
      text-align: center;
      font-family: "Helvetica", "Arial", sans-serif;
    }
  </style>
</head>
<body>
  {{ body | safe }}
</body>
</html>
