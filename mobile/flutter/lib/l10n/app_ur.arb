  "homeTip_eat_before_training": "خالی پیٹ تربیت کام کر سکتی ہے، لیکن 60-90 منٹ پہلے ایک چھوٹا کھانا زیادہ تر لوگوں کو بہتر کارکردگی میں مدد دیتا ہے۔",
  "homeTip_eccentric_focus": "نیچے جانے کا مرحلہ وہ ہے جہاں زیادہ تر پٹھوں کو نقصان (اور نشوونما) ہوتا ہے۔ اسے کنٹرول کریں۔",
  "homeTip_fiber_and_gut": "دن میں 30 گرام فائبر توانائی کو مستحکم رکھتا ہے اور خواہشات کو کم کرتا ہے۔ زیادہ تر لوگ 15 گرام حاصل کرتے ہیں۔",
  "homeTip_form_over_weight": "خراب فارم کے ساتھ ایگو لفٹس چوٹ کا باعث بنتی ہیں، پٹھوں کا نہیں۔ پہلے حرکت کو درست کریں۔",
  "homeTip_grip_strength": "گرفت کی طاقت لمبی عمر کی پیش گوئی تقریباً کسی بھی دوسرے میٹرک سے بہتر کرتی ہے۔ اس کی تربیت کریں۔",
  "homeTip_hydration_basics": "روزانہ اپنے جسمانی وزن کا نصف اونس میں پیئیں۔ تربیتی دنوں میں مزید شامل کریں۔",
  "homeTip_meal_timing_simple": "زیادہ تر مکمل غذائیں کھائیں، اپنا پروٹین پورا کریں، کافی نیند لیں۔ باقی سب شور ہے۔",
  "homeTip_mind_muscle_connection": "سست ہو جائیں اور پٹھوں کو کام کرتے ہوئے محسوس کریں۔ یہ صرف وزن اٹھانے کے بارے میں نہیں ہے۔",
  "homeTip_mobility_daily": "روزانہ 10 منٹ کی نقل و حرکت کی مشق ہفتے میں ایک بار 60 منٹ کے سیشن سے بہتر ہے۔",
  "homeTip_no_junk_volume": "10 سخت، مرکوز سیٹس 20 نیم دل سیٹس سے بہتر ہیں۔ مقدار سے زیادہ معیار۔",
  "homeTip_omega3_basics": "روزانہ 1-2 گرام EPA+DHA سوزش کو کم کرتا ہے اور جوڑوں کی صحت کو سپورٹ کرتا ہے۔",
  "homeTip_periodization": "وقت کے ساتھ ساتھ اپنے ریپ رینجز اور شدت کو تبدیل کریں۔ لکیری ترقی ہمیشہ نہیں رہتی۔",
  "homeTip_progressive_overload": "ہر ہفتے تھوڑا سا زیادہ وزن یا ایک اور ریپ شامل کریں۔ اسی طرح آپ بڑھتے ہیں۔",
  "homeTip_protein_per_meal": "ہر کھانے میں 30-40 گرام پروٹین کا ہدف رکھیں۔ اسے تقسیم کرنا ایک بڑی خوراک سے بہتر ہے۔",
  "homeTip_protein_sources_vary": "پروٹین کے ذرائع کو مکس کریں — چکن، انڈے، یونانی دہی، پھلیاں۔ تنوع تمام امینو ایسڈز کا احاطہ کرتا ہے۔",
  "homeTip_rate_of_perceived_exertion": "اپنی کوشش کو 1-10 درجہ دیں۔ زیادہ تر سیشنز میں 7-8 کے درمیان رہنا بہترین ہے۔",
  "homeTip_rest_days_grow_muscle": "آرام کے دن سستی نہیں ہیں — یہ وہ وقت ہے جب اصل میں بہتری آتی ہے۔",
  "homeTip_scale_not_everything": "وزن پانی اور خوراک سے روزانہ 2-4 پاؤنڈ اوپر نیچے ہوتا ہے۔ ہفتہ وار اوسط سے فیصلہ کریں۔",
  "homeTip_set_rep_ranges": "1-5 ریپس طاقت بناتے ہیں۔ 6-12 سائز بناتے ہیں۔ 12-20 برداشت بناتے ہیں۔ سب اہم ہیں۔",
  "homeTip_sleep_for_recovery": "آپ کے پٹھے ورزش کے دوران نہیں بڑھتے — وہ آپ کی نیند کے دوران بڑھتے ہیں۔",
  "homeTip_sodium_and_water": "نمک دشمن نہیں ہے — یہ ہائیڈریشن اور کارکردگی میں مدد کرتا ہے۔ اس سے نہ ڈریں۔",
  "homeTip_split_options": "پش/پل/لیگز، اپر/لوئر، فل باڈی 3x — سب کام کرتے ہیں اگر آپ مستقل مزاج ہیں۔",
  "homeTip_stress_and_recovery": "زیادہ تناؤ = زیادہ کورٹیسول = سست ریکوری۔ پوری تصویر کا انتظام کریں۔",
  "homeTip_tempo_training": "کسی بھی ورزش کو مختلف طریقے سے محسوس کرنے کے لیے 3-0-1 ٹیمپو (3 سیکنڈ نیچے، 0 وقفہ، 1 سیکنڈ اوپر) آزمائیں۔",
  "homeTip_track_to_progress": "اگر آپ اسے ٹریک نہیں کر رہے ہیں، تو آپ اسے سنبھال نہیں رہے ہیں۔ اپنے سیٹس لاگ کریں۔",
  "homeTip_vitamin_d": "زیادہ تر لوگوں میں وٹامن ڈی کی کمی ہوتی ہے۔ روزانہ 1000-2000 IU ایک محفوظ بنیاد ہے۔",
  "homeTip_walk_after_meals": "کھانے کے بعد 10 منٹ کی چہل قدمی آپ کے بلڈ شوگر کے اضافے کو 30 فیصد تک کم کر سکتی ہے۔",
  "homeTip_warm_up_matters": "5 منٹ کی موومنٹ پریپ ہر سیٹ کو محفوظ اور مضبوط بناتی ہے۔",
  "homeTip_zone2_cardio": "Zone 2 کارڈیو (بات چیت کی رفتار) ایروبک بنیاد بناتا ہے جس پر باقی سب کچھ ٹکا ہوا ہے۔",
