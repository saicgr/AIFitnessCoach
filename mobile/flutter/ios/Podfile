# Uncomment this line to define a global platform for your project
platform :ios, '16.1'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# flutter_gemma ships device-only xcframeworks (no arm64 simulator slices).
# We temporarily remove it from the plugins JSON before flutter_install_all_ios_pods
# reads it, then restore it afterwards so Flutter's own checks still pass.
require 'json'

SKIP_IOS_PLUGINS = %w[flutter_gemma]

plugins_file = File.expand_path(File.join('..', '.flutter-plugins-dependencies'), __dir__)
original_content = nil
if File.exist?(plugins_file)
  original_content = File.read(plugins_file)
  data = JSON.parse(original_content)
  data['plugins']['ios'] = data['plugins']['ios'].reject { |p| SKIP_IOS_PLUGINS.include?(p['name']) }
  File.write(plugins_file, JSON.generate(data))
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# Restore original plugins file so Flutter doesn't get confused
if original_content
  File.write(plugins_file, original_content)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Strip flutter_gemma from GeneratedPluginRegistrant.m since the pod isn't installed
  registrant = File.join(__dir__, 'Runner', 'GeneratedPluginRegistrant.m')
  if File.exist?(registrant)
    content = File.read(registrant)
    # Remove the #if/__has_include block for flutter_gemma
    content.gsub!(/^#if __has_include\(<flutter_gemma.*?\n.*?\n.*?@import flutter_gemma;\n#endif\n/m, '')
    # Remove the registration call
    content.gsub!(/.*FlutterGemmaPlugin.*\n/, '')
    File.write(registrant, content)
  end
end
