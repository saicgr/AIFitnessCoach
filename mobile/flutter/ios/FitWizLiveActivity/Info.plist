<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Zealova Live Activity</string>
	<!--
		iOS 26 simulator regression — `simctl install` fails with
		"Invalid placeholder attributes / Failed to create app extension
		placeholder" when the WidgetKit/Live Activity extension's Info.plist
		does not declare these keys explicitly:

		- NSExtensionAttributes (even an empty dict is enough; iOS 26's
		  placeholder validator refuses extensions where the key is missing).
		- NSExtensionPrincipalClass — WidgetKit extensions auto-discover the
		  principal Widget bundle via @main; this key is allowed to be empty
		  but must be PRESENT for the iOS 26 sim installer to build the
		  placeholder bundle. Production devices were unaffected.

		Adding both unblocks `flutter run` on iOS 26 simulators without
		changing runtime behaviour. Cleared once Apple fixes the sim regression.
	-->
	<!--
		Explicit version keys: with GENERATE_INFOPLIST_FILE the merged appex
		plist was shipping WITHOUT CFBundleVersion/CFBundleShortVersionString,
		which the iOS 26 sim installer also rejects as "Invalid placeholder
		attributes". LITERALS, not $(MARKETING_VERSION)/$(CURRENT_PROJECT_VERSION):
		those resolve EMPTY for this target (Generated.xcconfig with
		FLUTTER_BUILD_NAME/NUMBER is only included by the Runner target) and
		Xcode silently drops empty-valued keys, reproducing the install failure.
		App Store requires the appex CFBundleShortVersionString to match the
		app's — bump these alongside pubspec.yaml `version:` before an iOS
		release (durable fix = include Generated.xcconfig in the extension
		target's build configs; do that in the iOS release pass).
	-->
	<key>CFBundleShortVersionString</key>
	<string>1.2.67</string>
	<key>CFBundleVersion</key>
	<string>1140</string>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionAttributes</key>
		<dict/>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.widgetkit-extension</string>
		<key>NSExtensionPrincipalClass</key>
		<string></string>
	</dict>
	<key>NSSupportsLiveActivities</key>
	<true/>
</dict>
</plist>
